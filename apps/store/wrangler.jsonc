{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "react-router-app",
  "compatibility_date": "2025-04-04",
  "main": "./workers/app.ts",
  "vars": {
    "VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare"
  },
  "observability": {
    "logs": {
      "enabled": true
    }
  },
  "r2_buckets": [{
    "binding": "BUCKET",
    "bucket_name": "catalyzer"
  }]
}
